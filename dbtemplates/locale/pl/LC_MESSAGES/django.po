msgid ""
"Leaving this empty causes Django to look for a template with the given name "
"and populate this field with its content."
msgstr ""
"Pozostawienie tego pola pustym spowoduje, że Django wyszuka szablon o "
"podanej nazwie i wypełni to pole jego zawartością."

msgid "Advanced"
msgstr "Zaawansowane"

msgid "Date/time"
msgstr "Data/czas"

#, python-format
msgid "Cache of one template successfully invalidated."
msgid_plural "Cache of %(count)d templates successfully invalidated."
msgstr[0] "Pomyślnie unieważniono pamięć podręczną jednego szablonu."
msgstr[1] "Pomyślnie unieważniono pamięć podręczną %(count)d szablonów."
msgstr[2] "Pomyślnie unieważniono pamięć podręczną %(count)d szablonów."

msgid "Invalidate cache of selected templates"
msgstr "Unieważnij pamięć podręczną wybranych szablonów"

#, python-format
msgid "Cache successfully repopulated with one template."
